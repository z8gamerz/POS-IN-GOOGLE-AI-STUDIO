{
  "rules": {
    /* 
      FIREBASE REALTIME DATABASE SECURITY RULES
      =========================================
      
      This file provides hardened security and schema validation for your POS sync data.
      These rules enforce:
      1. ROLE-BASED ACCESS: Administrators have unrestricted read/write access.
      2. BRANCH ISOLATION: Cashiers can only read and write data (products, transactions, 
         expenses, customers, etc.) belonging to branches assigned to them in their 
         "assignedBranchIds" record.
      
      To deploy these rules:
      1. Open your Firebase Console (https://console.firebase.google.com/)
      2. Navigate to "Realtime Database" and click on the "Rules" tab.
      3. Paste this JSON content and click "Publish".
    */

    ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
    ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",

    "users": {
      "$userId": {
        // Anyone logged in can read a user record to check profiles, but write is admin-only or self
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.uid === $userId)",
        ".validate": "newData.hasChildren(['id', 'name', 'email', 'passwordHash', 'role'])",
        "id": { ".validate": "newData.isString() && newData.val() == $userId" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "email": { ".validate": "newData.isString() && newData.val().contains('@')" },
        "passwordHash": { ".validate": "newData.isString()" },
        "role": { ".validate": "newData.val() == 'admin' || newData.val() == 'cashier'" },
        "assignedBranchIds": { ".validate": "true" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "products": {
      "$productId": {
        // Read is allowed if admin, or if product's branchId is in user's assigned branches list
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))",
        // Write is allowed if admin, or if product's branchId is in user's assigned branches list
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(newData.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(newData.child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'name', 'price', 'cost', 'stock', 'category', 'branchId'])",
        "id": { ".validate": "newData.isString() && newData.val() == $productId" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "price": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "cost": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "stock": { ".validate": "newData.isNumber()" },
        "category": { ".validate": "newData.isString()" },
        "branchId": { ".validate": "newData.isString()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "transactions": {
      "$transactionId": {
        // Enforce same branch checks on read/write for transactions
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(newData.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(newData.child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'ticketNumber', 'total', 'timestamp', 'branchId'])",
        "id": { ".validate": "newData.isString() && newData.val() == $transactionId" },
        "ticketNumber": { ".validate": "newData.isString()" },
        "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "timestamp": { ".validate": "newData.isNumber()" },
        "branchId": { ".validate": "newData.isString()" },
        "paymentMethod": { ".validate": "newData.val() == 'cash' || newData.val() == 'gcash' || newData.val() == 'credit' || newData.val() == 'split'" },
        "isPaid": { ".validate": "newData.isBoolean()" },
        "remainingCreditBalance": { ".validate": "!newData.exists() || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "customers": {
      "$customerId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(newData.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(newData.child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'name', 'totalUtang', 'branchId'])",
        "id": { ".validate": "newData.isString() && newData.val() == $customerId" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "totalUtang": { ".validate": "newData.isNumber()" },
        "branchId": { ".validate": "newData.isString()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "credit_log": {
      "$logId": {
        // Allow read/write if the log's customer belongs to an assigned branch
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(root.child('customers').child(data.child('customerId').val()).child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(root.child('customers').child(data.child('customerId').val()).child('branchId').val()))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(root.child('customers').child(newData.child('customerId').val()).child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(root.child('customers').child(newData.child('customerId').val()).child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(root.child('customers').child(data.child('customerId').val()).child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(root.child('customers').child(data.child('customerId').val()).child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'customerId', 'amount', 'type'])",
        "id": { ".validate": "newData.isString() && newData.val() == $logId" },
        "customerId": { ".validate": "newData.isString()" },
        "amount": { ".validate": "newData.isNumber()" },
        "type": { ".validate": "newData.val() == 'credit' || newData.val() == 'payment'" },
        "timestamp": { ".validate": "newData.isNumber()" }
      }
    },

    "expenses": {
      "$expenseId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(newData.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(newData.child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'amount', 'category', 'timestamp', 'branchId'])",
        "id": { ".validate": "newData.isString() && newData.val() == $expenseId" },
        "amount": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "category": { ".validate": "newData.isString()" },
        "branchId": { ".validate": "newData.isString()" },
        "timestamp": { ".validate": "newData.isNumber()" }
      }
    },

    "categories": {
      "$categoryId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(newData.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(newData.child('branchId').val()))) || (!newData.exists() && (root.child('users').child(auth.uid).child('assignedBranchIds').child(data.child('branchId').val()).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains(data.child('branchId').val()))))",
        ".validate": "newData.hasChildren(['id', 'name', 'branchId'])",
        "id": { ".validate": "newData.isString() && newData.val() == $categoryId" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "branchId": { ".validate": "newData.isString()" }
      }
    },

    "branches": {
      "$branchId": {
        // Read is allowed if assigned or admin
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('assignedBranchIds').child($branchId).exists() || root.child('users').child(auth.uid).child('assignedBranchIds').val().contains($branchId))",
        // Admin only can register branches
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['id', 'name'])",
        "id": { ".validate": "newData.isString() && newData.val() == $branchId" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0" }
      }
    }
  }
}
